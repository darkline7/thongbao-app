# Sao chép file này thành .env và điền thông tin thực
# cp .env.example .env

# Port server (mặc định 4173)
PORT=4173

# Firebase credentials (dùng cho HTTP polling)
# Lấy từ tài khoản thongbao.shop của bạn
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_REFRESH_TOKEN=your_firebase_refresh_token_here
